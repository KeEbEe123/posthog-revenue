{
  "name": "@revenue-recipes/dashboard",
  "version": "0.1.0",
  "description": "Standalone visual dashboard — the replacement for PostHog's deprecated Revenue Analytics dashboard.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace @revenue-recipes/core",
    "dev": "vite",
    "prebuild": "npm run build --workspace @revenue-recipes/core",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@revenue-recipes/core": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0",
    "vite": "^5.3.1"
  }
}
