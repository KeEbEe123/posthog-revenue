# Copy to .env.local (gitignored) to make the dashboard auto-connect to a live
# PostHog project on load, persisting across refresh.
#
# WARNING: VITE_ vars are baked into the client bundle — the API key is visible
# to anyone who can open the page. Local dev only; never for a public deploy.
#
# Uses a PERSONAL API key (phx_...) with query read scope — NOT the phc_
# ingestion key.
VITE_POSTHOG_HOST=https://us.posthog.com
VITE_POSTHOG_PROJECT_ID=12345
VITE_POSTHOG_PERSONAL_API_KEY=phx_your_personal_key_here
