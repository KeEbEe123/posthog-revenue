# Copy to .env and fill in to connect the MCP server / Node clients to a real
# PostHog project. NEVER commit the real .env — it is gitignored.
#
# Personal API key with query (read) scope. Create at:
#   PostHog -> Settings -> Personal API keys
POSTHOG_PERSONAL_API_KEY=phx_your_key_here

# Numeric project ID (PostHog -> Settings -> Project).
POSTHOG_PROJECT_ID=12345

# Your PostHog host (US cloud, EU cloud, or self-hosted).
POSTHOG_HOST=https://us.posthog.com
